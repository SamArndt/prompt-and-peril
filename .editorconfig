# http://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
# Python's PEP 8 standard requires 4 spaces
indent_size = 4

[*.html]
# Django templates usually follow 2-space indentation
indent_size = 2

[*.{js,css,scss}]
indent_size = 2

[Makefile]
indent_style = tab
